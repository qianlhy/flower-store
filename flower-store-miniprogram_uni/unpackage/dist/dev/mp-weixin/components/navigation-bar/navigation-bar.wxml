<view class="{{['weui-navigation-bar '+extClass]}}"><view class="{{['weui-navigation-bar__inner '+(ios?'ios':'android')]}}" style="{{('color: '+color+'; background: '+background+'; '+displayStyle+'; '+innerPaddingRight+'; '+safeAreaTop+';')}}"><view class="weui-navigation-bar__left" style="{{(leftWidth+';')}}"><block wx:if="{{back||homeButton}}"><block><block wx:if="{{back}}"><block><view class="weui-navigation-bar__buttons weui-navigation-bar__buttons_goback"><view class="weui-navigation-bar__btn_goback_wrapper" hover-class="weui-active" hover-stay-time="100" aria-role="button" aria-label="返回" data-event-opts="{{[['tap',[['backFun',['$event']]]]]}}" bindtap="__e"><view class="weui-navigation-bar__button weui-navigation-bar__btn_goback"></view></view></view></block></block><block wx:if="{{homeButton}}"><block><view class="weui-navigation-bar__buttons weui-navigation-bar__buttons_home"><view class="weui-navigation-bar__btn_home_wrapper" hover-class="weui-active" aria-role="button" aria-label="首页" data-event-opts="{{[['tap',[['home',['$event']]]]]}}" bindtap="__e"><view class="weui-navigation-bar__button weui-navigation-bar__btn_home"></view></view></view></block></block></block></block><block wx:else><block><slot name="left"></slot></block></block></view><view class="weui-navigation-bar__center"><block wx:if="{{loading}}"><view class="weui-navigation-bar__loading" aria-role="alert"><view class="weui-loading" aria-role="img" aria-label="加载中"></view></view></block><block wx:if="{{title}}"><block><text>{{title}}</text></block></block><block wx:else><block><slot name="center"></slot></block></block></view><view class="weui-navigation-bar__right"><slot name="right"></slot></view></view></view>