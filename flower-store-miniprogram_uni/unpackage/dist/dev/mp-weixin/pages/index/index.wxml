<view><view class="index-container"><view class="search-bar"><view data-event-opts="{{[['tap',[['onTapSearch',['$event']]]]]}}" class="search-input-box" bindtap="__e"><icon type="search" size="16" color="#999"></icon><text class="search-placeholder">搜索玫瑰、百合、康乃馨等</text></view></view><view data-event-opts="{{[['tap',[['toggleBackgroundAudio',['$event']]]]]}}" class="music-control" bindtap="__e"><image class="{{['music-icon '+(backgroundAudioPlaying?'playing':'')]}}" src="/static/images/icons/music.png"></image></view><swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" duration="500" circular="{{true}}"><block wx:for="{{banners}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="banner-image" src="{{item.image}}" mode="aspectFill" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapBanner',['$event']]]]]}}" bindtap="__e"></image></swiper-item></block></swiper><view class="category-nav"><scroll-view class="category-scroll" scroll-x="{{true}}"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="category-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e"><image class="category-icon" src="{{item.icon||'/images/category/default.png'}}"></image><text class="category-name">{{item.name}}</text></view></block></scroll-view></view><view class="section"><view class="section-header"><text class="section-title">限时特惠</text><text class="section-more" data-type="promotion" data-event-opts="{{[['tap',[['onTapMore',['$event']]]]]}}" bindtap="__e">查看更多 ></text></view><view class="promotion-box"><block wx:for="{{promotions}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="promotion-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="promotion-image" src="{{item.image}}" mode="aspectFill"></image><view class="promotion-info"><text class="promotion-name text-ellipsis">{{item.name}}</text><view class="promotion-price-box"><text class="price">{{"¥"+item.price}}</text><text class="price-original">{{"¥"+item.originalPrice}}</text></view></view></view></block></view></view><view class="section"><view class="section-header"><text class="section-title">热门推荐</text><text class="section-more" data-type="recommended" data-event-opts="{{[['tap',[['onTapMore',['$event']]]]]}}" bindtap="__e">查看更多 ></text></view><view class="product-list"><block wx:for="{{recommendProducts}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="product-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><text class="product-name text-ellipsis">{{item.name}}</text><text class="product-desc text-ellipsis">{{item.description}}</text><view class="product-price-box"><text class="price">{{"¥"+item.price}}</text><text class="price-original">{{"¥"+item.originalPrice}}</text></view><view class="product-sales">{{"已售"+item.sales+"件"}}</view></view><view class="add-cart-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onAddToCart',['$event']]]]]}}" catchtap="__e">+</view></view></block></view></view><view class="section"><view class="section-header"><text class="section-title">新品上市</text><text class="section-more" data-type="new" data-event-opts="{{[['tap',[['onTapMore',['$event']]]]]}}" bindtap="__e">查看更多 ></text></view><view class="grid grid-2"><block wx:for="{{newProducts}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="grid-item new-product" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="new-product-image" src="{{item.image}}" mode="aspectFill"></image><view class="new-product-info"><text class="new-product-name text-ellipsis">{{item.name}}</text><view class="new-product-price-box"><text class="price">{{"¥"+item.price}}</text></view><view class="tag tag-primary">新品</view></view></view></block></view></view></view><block wx:if="{{showToast}}"><view class="toast-container"><view class="toast-content"><icon type="success" size="24"></icon><text>已加入购物车</text></view></view></block></view>