<view><view class="category-container"><view class="category-sidebar"><scroll-view class="sidebar-scroll" scroll-y="{{true}}"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['category-item '+(currentCategory.id===item.id?'active':'')]}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchCategory',['$event']]]]]}}" bindtap="__e"><view class="category-item-inner">{{item.name}}</view></view></block></scroll-view></view><view class="category-content"><block wx:if="{{currentCategory}}"><view class="category-title"><text>{{currentCategory.name}}</text></view></block><scroll-view class="product-scroll" scroll-y="{{true}}"><block wx:if="{{$root.g0===0}}"><view class="no-data"><image src="/static/images/icons/empty.png" mode="aspectFit"></image><text>暂无商品</text></view></block><view class="product-list"><block wx:for="{{products}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="product-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><text class="product-name text-ellipsis">{{item.name}}</text><text class="product-desc text-ellipsis">{{item.description}}</text><view class="product-price-box"><text class="price">{{"¥"+item.price}}</text><text class="price-original">{{"¥"+item.originalPrice}}</text></view><view class="product-sales">{{"已售"+item.sales+"件"}}</view></view><view class="add-cart-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onAddToCart',['$event']]]]]}}" catchtap="__e">+</view></view></block></view></scroll-view></view></view><block wx:if="{{isLoading}}"><view class="loading-container"><view class="loading"><image class="loading-icon" src="/static/images/icons/loading.png" mode="aspectFit"></image><text>加载中...</text></view></view></block></view>