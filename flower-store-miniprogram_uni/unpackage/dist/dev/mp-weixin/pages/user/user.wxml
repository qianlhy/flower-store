<view class="user-container"><view class="user-header"><view class="header-bg"></view><view class="user-info"><block wx:if="{{isLogin}}"><view class="avatar-box"><image class="user-avatar" src="{{userInfo.avatarUrl||'/images/icons/default-avatar.png'}}"></image></view></block><block wx:else><view data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="avatar-box" bindtap="__e"><image class="user-avatar" src="/static/images/icons/default-avatar.png"></image></view></block><block wx:if="{{isLogin}}"><view class="user-name"><text>{{userInfo.nickName||'微信用户'}}</text></view></block><block wx:else><view data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-btn" bindtap="__e"><text>点击登录</text></view></block></view></view><block wx:if="{{!isLogin}}"><view class="login-prompt"><view class="login-prompt-text">登录后查看您的订单和个人信息</view><button data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="primary-login-btn" bindtap="__e">立即登录/注册</button></view></block><block wx:if="{{isLogin}}"><view class="order-section"><view data-event-opts="{{[['tap',[['viewAllOrders',['$event']]]]]}}" class="section-header" bindtap="__e"><text class="section-title">我的订单</text><view class="section-more"><text>全部订单</text><text class="arrow">></text></view></view><view class="order-types"><view class="order-type" data-status="待付款" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><view class="order-icon-wrap"><image class="order-icon" src="/static/images/icons/unpaid.png"></image><block wx:if="{{orderStats.unpaid>0}}"><view class="order-badge">{{orderStats.unpaid}}</view></block></view><text>待付款</text></view><view class="order-type" data-status="待发货" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><view class="order-icon-wrap"><image class="order-icon" src="/static/images/icons/unshipped.png"></image><block wx:if="{{orderStats.unshipped>0}}"><view class="order-badge">{{orderStats.unshipped}}</view></block></view><text>待发货</text></view><view class="order-type" data-status="待收货" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><view class="order-icon-wrap"><image class="order-icon" src="/static/images/icons/shipped.png"></image><block wx:if="{{orderStats.shipped>0}}"><view class="order-badge">{{orderStats.shipped}}</view></block></view><text>待收货</text></view><view class="order-type" data-status="已完成" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><view class="order-icon-wrap"><image class="order-icon" src="/static/images/icons/completed.png"></image><block wx:if="{{orderStats.completed>0}}"><view class="order-badge">{{orderStats.completed}}</view></block></view><text>已完成</text></view></view></view></block><view class="features"><view class="feature-item" data-url="/pages/address/list" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><image class="feature-icon" src="/static/images/icons/address.png"></image><text>收货地址</text><text class="arrow">></text></view><view class="feature-item" data-url="/pages/collection/collection" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><image class="feature-icon" src="/static/images/icons/favorite.png"></image><text>我的收藏</text><text class="arrow">></text></view><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="feature-item" bindtap="__e"><image class="feature-icon" src="/static/images/icons/service.png"></image><text>联系客服</text><text class="arrow">></text></view><view class="feature-item" data-url="/pages/settings/settings" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><image class="feature-icon" src="/static/images/icons/settings.png"></image><text>设置</text><text class="arrow">></text></view><block wx:if="{{isLogin}}"><view data-event-opts="{{[['tap',[['logout',['$event']]]]]}}" class="feature-item" bindtap="__e"><image class="feature-icon" src="/static/images/icons/logout.png"></image><text>退出登录</text><text class="arrow">></text></view></block></view><view class="version-info"><text>鲜花铺子 v1.0.0</text></view></view>